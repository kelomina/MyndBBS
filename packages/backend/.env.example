JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
# Optional: separate secret for installation temporary tokens. Falls back to JWT_SECRET if not set.
# 可选：安装流程临时令牌专用密钥。未设置时回退到 JWT_SECRET。
# TEMP_TOKEN_SECRET=change-me-install
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false
PORT=3001
DATABASE_URL="postgresql://postgres:password@localhost:5432/myndbbs?schema=public"
RP_ID=localhost
ORIGIN=http://localhost:3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=MyndBBS <no-reply@example.com>
EMAIL_VERIFICATION_TTL_MINUTES=30
PASSWORD_RESET_TTL_MINUTES=30
