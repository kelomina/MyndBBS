JWT_SECRET=<generate-64-random-hex-characters>
JWT_REFRESH_SECRET=<generate-a-different-64-random-hex-characters>
# Production requires a separate temporary-token secret. Use a third value different from both JWT secrets.
# 生产环境必须配置安装/临时令牌专用密钥，并且必须不同于 JWT_SECRET 和 JWT_REFRESH_SECRET。
TEMP_TOKEN_SECRET=<generate-a-third-64-random-hex-secret>
# Database password used by docker-compose for POSTGRES_PASSWORD and DATABASE_URL interpolation.
# Docker Compose 部署时用于 POSTGRES_PASSWORD 和 DATABASE_URL 插值的数据库密码。
DB_PASSWORD=<generate-a-strong-database-password>
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false
PORT=3001
DATABASE_URL="postgresql://postgres:<database-password>@localhost:5432/myndbbs?schema=public"
REDIS_PASSWORD=<generate-a-strong-redis-password>
REDIS_URL=redis://:<redis-password>@localhost:6379
RP_ID=localhost
ORIGIN=http://localhost:3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=MyndBBS <no-reply@example.com>
EMAIL_VERIFICATION_TTL_MINUTES=30
PASSWORD_RESET_TTL_MINUTES=30
# Keep installation locked by default. For first-time local setup only, set INSTALL_LOCKED=false.
# 默认关闭安装向导。仅首次本地初始化时临时改为 INSTALL_LOCKED=false。
INSTALL_LOCKED=true
NODE_ENV=development
